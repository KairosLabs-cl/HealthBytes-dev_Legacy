# ESTE ES UN .env Generico NO LO TOME EN CUENTA EN 
# PROXIMOS COMMITS SERA CAMBIADO COMO ES NECESARIO PARA EL DESARROLLO
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
***REDACTED_DATABASE_URL***

# JWT Configuration (Legacy - for backwards compatibility)
# Secret key for JWT token signing
JWT_SECRET=your-secret-key-here
# Algorithm for JWT tokens
JWT_ALGORITHM=HS256
# Token expiration time in minutes (default: 43200 = 30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Clerk Authentication
# Get these from your Clerk dashboard: https://dashboard.clerk.com
# Publishable key (starts with pk_test_ or pk_live_)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Secret key (starts with sk_test_ or sk_live_)
***REDACTED_CLERK_SECRET_KEY***

# Stripe Configuration
# Get these from your Stripe dashboard: https://dashboard.stripe.com
# Secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Webhook secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Environment Configuration
# Options: dev, staging, production
ENVIRONMENT=dev
# Server host (default: 0.0.0.0)
HOST=0.0.0.0
# Server port (default: 3001)
PORT=3001
