# Para desarrollo local en NAVEGADOR WEB - usar localhost:
EXPO_PUBLIC_API_URL=http://localhost:3001

# Para desarrollo local en CELULAR/EMULADOR - comentar la línea de arriba y descomentar esta:
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3001
# IMPORTANTE: Reemplaza 192.168.1.x con tu IP local real (usa: ip route get 1.1.1.1 | awk '{print $7}' | head -n1)

# Clerk Authentication
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY_REDACTED