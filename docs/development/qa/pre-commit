#!/bin/sh
# HealthBytes pre-commit hook — validates docs metrics are within expected ranges.
# Install: copy or symlink to .git/hooks/pre-commit
# Or run: python docs/.automation/docsync.py --install-hook

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/docs/.automation/docsync.py"

if [ ! -f "$SCRIPT" ]; then
  echo "[docsync] pre-commit hook: script not found at $SCRIPT, skipping"
  exit 0
fi

python "$SCRIPT" --validate
exit $?
