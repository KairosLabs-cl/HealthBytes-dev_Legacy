 # Example environment file - copy to .env and fill in your values

# ==========================================
# Database Configuration
# ==========================================
DB_USER=healthbytes
DB_PASSWORD=healthbytes_dev
DB_NAME=healthbytes

# ==========================================
# Authentication & Security
# ==========================================
# JWT Secret (generate a strong one for production)
JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# Clerk Auth Keys (get from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
***REDACTED_CLERK_SECRET_KEY***

# ==========================================
# Application Configuration
# ==========================================
ENVIRONMENT=development
LOG_LEVEL=info

# Backend & Frontend URLs (for payment callbacks)
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8081

# Redis removed - not used in this project

# ==========================================
# Frontend Configuration
# ==========================================
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ==========================================
# Payment Providers
# ==========================================
# Stripe (Legacy)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOKOOK_SECRET=whsec_...

# Mercado Pago (Chile - Primary)
# Get your keys from: https://www.mercadopago.cl/developers/panel
***REDACTED_MERCADOPAGO_TOKEN***
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-here
