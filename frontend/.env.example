# HealthBytes Frontend - Environment Variables
# DO NOT commit the actual .env file to git
# Template: Copy to .env and update with your actual values

# ============================================
# QUICK SETUP (Recommended)
# ============================================
# Run the automatic setup script:
#   powershell -ExecutionPolicy Bypass -File .\setup-env.ps1
#
# The script will detect your IP and configure everything automatically
# ============================================

# Backend API URL
# - For web-only development: http://localhost:3001
# - For mobile/emulator: http://YOUR_LOCAL_IP:3001 (e.g., http://192.168.1.127:3001)
# - For both: use your local IP (works in both cases)
EXPO_PUBLIC_API_URL=http://localhost:3001

# Clerk Authentication
# Get your key from: https://dashboard.clerk.com/
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. To get your local IP on Windows:
#    ipconfig | Select-String "IPv4"
#
# 2. Localhost (127.0.0.1) does NOT work with Expo Go
#    You must use your local network IP (192.168.x.x)
#
# 3. Make sure your phone and computer are on the
#    SAME WiFi network
#
# 4. If your IP changes, update this file or
#    re-run setup-env.ps1

