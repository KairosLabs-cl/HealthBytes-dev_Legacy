      "node-forge": "~1.4.0",
      "brace-expansion": "~5.0.6",
      "yaml": "~2.8.3",
      "@tootallnate/once": "~3.0.1",
      "@clerk/types": "4.101.20"
    },
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "browser-tabs-lock",
      "bufferutil",
      "core-js",
      "utf-8-validate"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18 || 19",
        "react-dom": "18 || 19"
      }
    }
  },
  "private": true
}
