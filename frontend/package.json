{
  "name": "healthbytes",
  "version": "0.4.0",
  "main": "expo-router/entry",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "start": "bash ./start.sh",
    "android": "bash ./start.sh --android",
    "ios": "bash ./start.sh --ios",
    "web": "bash ./start.sh --web",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "bash ./start.sh --clear",
    "prebuild": "pnpm run type-check",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:production": "npx eas-cli build --platform android --profile production",
    "build:android:local": "expo prebuild && cd android && ./gradlew assembleRelease",
    "build:android:development": "npx eas-cli build --platform android --profile development"
  },
  "dependencies": {
    "@clerk/clerk-expo": "2.19.36",
    "@expo/html-elements": "^0.13.8",
    "@expo/metro-runtime": "^6.1.2",
    "@gluestack-ui/button": "^1.0.14",
    "@gluestack-ui/form-control": "^0.1.19",
    "@gluestack-ui/icon": "^0.1.27",
    "@gluestack-ui/image": "^0.1.17",
    "@gluestack-ui/input": "^0.1.38",
    "@gluestack-ui/nativewind-utils": "^1.0.28",
    "@gluestack-ui/overlay": "^0.1.22",
    "@gluestack-ui/toast": "^1.0.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.16.2",
    "@sentry/react-native": "^7.2.0",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/react-query": "^5.90.19",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-device": "^8.0.10",
    "expo-font": "^14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.562.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.1.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jscodeshift": "^17.3.0",
    "prettier": "^3.8.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "bs58": "^6.0.0",
      "minimatch": "^10.2.3",
      "glob": "^11.0.0",
      "babel-plugin-module-resolver>glob": "^8",
      "tar": ">=7.5.10",
      "@clerk/shared": "~3.47.4",
      "flatted": "~3.4.2",
      "lodash": "~4.18.0",
      "undici": "~6.24.0",
      "picomatch": "~4.0.4",
