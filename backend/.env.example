# ========================================
# DATABASE
# ========================================
# PostgreSQL connection string
# Importante: Cambialo y adjunta el url del documento de clerk
DATABASE_URL=postgresql://user:password@localhost:5432/healthbytes_dev

# ========================================
# AUTHENTICATION - CLERK (Nueva Plataforma)
# ========================================
# Obtén keys en https://dashboard.clerk.com
# Dashboard → API Keys → Copy to .env
CLERK_PUBLISHABLE_KEY=pk_test_XXXxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_XXXxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# AUTHENTICATION - JWT (Legacy)
# ========================================
# Para generar un secret seguro en Python:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_secret_key_here_minimo_32_caracteres_aleatorios
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ========================================
# MERCADO PAGO (Chile)
# ========================================
# Obtén credenciales en: https://www.mercadopago.cl/developers

MERCADO_PAGO_ACCESS_TOKEN=TEST-1234567890-your-test-token-here
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-from-mp-panel

# URLs de callback (para que MP sepa dónde redirigir después de pagar)
# En desarrollo:
BACKEND_URL=http://127.0.0.1:3001
FRONTEND_URL=http://localhost:8081
#
# En producción:
# BACKEND_URL=https://api.healthbytes.cl
# FRONTEND_URL=https://app.healthbytes.cl
# ========================================
# ENVIRONMENT
# ========================================
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=3001
